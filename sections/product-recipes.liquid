{% assign recipe_blog = blogs[section.settings.blog] %}
{% assign recipe_count = 0 %}

{% if recipe_blog != blank %}
  {% for article in recipe_blog.articles %}
    {% if article.metafields.custom.product_handle == product.handle %}
      {% assign recipe_count = recipe_count | plus: 1 %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if recipe_count > 0 %}
  <div class="max-w-6xl mx-auto px-4 py-10 border-t border-gray-200">
    <h2 class="text-2xl md:text-3xl font-bold text-center uppercase mb-2">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="text-center text-gray-600 mb-8">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% assign shown = 0 %}
      {% for article in recipe_blog.articles %}
        {% if article.metafields.custom.product_handle == product.handle and shown < section.settings.recipes_to_show %}
          {% assign shown = shown | plus: 1 %}
          <div class="bg-white rounded-xl shadow p-4 border border-gray-100">
            <a href="{{ article.url }}" class="block group">
              {% if article.image != blank %}
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.title }}"
                  class="w-full h-44 object-cover rounded-lg mb-3 group-hover:opacity-90 transition"
                  loading="lazy"
                >
              {% else %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ article.title }}"
                  class="w-full h-44 object-cover rounded-lg mb-3 group-hover:opacity-90 transition"
                  loading="lazy"
                >
              {% endif %}
              <h3 class="font-semibold text-lg mb-2 group-hover:underline">{{ article.title }}</h3>
              <p class="text-sm text-gray-600 mb-3">{{ article.excerpt | strip_html | truncatewords: 18 }}</p>
              <span class="text-[#ffb045] font-semibold text-sm">{{ section.settings.read_more_text }} →</span>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.view_all_link != blank %}
      <div class="text-center mt-8">
        <a href="{{ section.settings.view_all_link }}" class="inline-block uppercase font-bold border border-black px-6 py-2 rounded-lg hover:bg-gray-50 transition">
          {{ section.settings.view_all_text }}
        </a>
      </div>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Product Recipes",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Recipes blog only",
      "info": "Must be the Recipes blog, not Events."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recipes with this product"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Caribbean-inspired ideas from the GG's kitchen"
    },
    {
      "type": "range",
      "id": "recipes_to_show",
      "label": "Recipes to show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more label",
      "default": "View recipe"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "See all recipes"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Product Recipes"
    }
  ]
}
{% endschema %}
