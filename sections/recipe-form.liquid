{% assign all_products = collections.all.products %}

{% if customer %}
  <div class="max-w-3xl mx-auto py-10 px-6">
    <h2 class="text-3xl font-bold mb-6 text-center">Submit Your Recipe</h2>

    <form id="recipeForm" class="space-y-4">
      <input type="hidden" name="customer_email" value="{{ customer.email }}">
      <input type="hidden" name="image_url" id="imageUrl" value="">

      <div>
        <label class="block font-semibold" for="recipeName">Your Name</label>
        <input type="text" id="recipeName" name="name" value="{{ customer.first_name }} {{ customer.last_name }}" class="w-full p-2 border rounded" required>
      </div>

      <div>
        <label class="block font-semibold" for="recipeTitle">Recipe Title</label>
        <input type="text" id="recipeTitle" name="recipe_title" class="w-full p-2 border rounded" required>
      </div>

      <div>
        <label class="block font-semibold" for="productHandle">Product Used</label>
        <select id="productHandle" name="product_handle" class="w-full p-2 border rounded" required>
          <option value="">-- Select a Product --</option>
          {% for product in all_products %}
            <option value="{{ product.handle }}">{{ product.title }}</option>
          {% endfor %}
        </select>
      </div>

      <div>
        <label class="block font-semibold" for="imageUpload">Recipe Image</label>
        <input type="file" id="imageUpload" name="image" accept="image/*" class="w-full p-2 border rounded">
        <p id="imageUploadStatus" class="text-sm text-gray-500 mt-1">Optional. Max 5MB.</p>
      </div>

      <div>
        <label class="block font-semibold" for="recipeInstructions">Recipe Instructions</label>
        <textarea id="recipeInstructions" name="recipe" class="w-full p-2 border rounded h-32" required></textarea>
      </div>

      <button type="submit" id="recipeSubmitBtn" class="bg-[#ffb045] hover:bg-[#e59b30] px-6 py-2 text-white font-semibold rounded">
        Submit Recipe
      </button>
    </form>

    <div id="form-message" class="mt-4 text-center text-sm"></div>

    <script>
      (function () {
        const imageInput = document.getElementById('imageUpload');
        const imageUrlInput = document.getElementById('imageUrl');
        const imageStatus = document.getElementById('imageUploadStatus');
        const form = document.getElementById('recipeForm');
        const submitBtn = document.getElementById('recipeSubmitBtn');
        const messageEl = document.getElementById('form-message');

        imageInput.addEventListener('change', async function (e) {
          const file = e.target.files[0];
          imageUrlInput.value = '';

          if (!file) {
            imageStatus.textContent = 'Optional. Max 5MB.';
            imageStatus.className = 'text-sm text-gray-500 mt-1';
            return;
          }

          if (file.size > 5 * 1024 * 1024) {
            imageStatus.textContent = 'File too large. Please upload an image under 5MB.';
            imageStatus.className = 'text-sm text-red-600 mt-1';
            imageInput.value = '';
            return;
          }

          imageStatus.textContent = 'Uploading image...';
          imageStatus.className = 'text-sm text-gray-600 mt-1';

          const formData = new FormData();
          formData.append('image', file);

          try {
            const response = await fetch('https://shopify-recipes-api.vercel.app/api/upload-image', {
              method: 'POST',
              body: formData
            });

            if (response.ok) {
              const data = await response.json();
              imageUrlInput.value = data.url;
              imageStatus.textContent = 'Image uploaded successfully.';
              imageStatus.className = 'text-sm text-green-600 mt-1';
            } else {
              imageStatus.textContent = 'Image upload failed. You can still submit without an image.';
              imageStatus.className = 'text-sm text-red-600 mt-1';
            }
          } catch (error) {
            imageStatus.textContent = 'Image upload failed. You can still submit without an image.';
            imageStatus.className = 'text-sm text-red-600 mt-1';
          }
        });

        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          submitBtn.disabled = true;
          submitBtn.textContent = 'Submitting...';

          const data = {
            customer_email: form.querySelector('[name="customer_email"]').value,
            name: form.querySelector('[name="name"]').value,
            recipe_title: form.querySelector('[name="recipe_title"]').value,
            product_handle: form.querySelector('[name="product_handle"]').value,
            recipe: form.querySelector('[name="recipe"]').value,
            image_url: imageUrlInput.value
          };

          try {
            const response = await fetch('https://shopify-recipes-api.vercel.app/api/submit-recipe', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(data)
            });

            if (response.ok) {
              form.reset();
              imageUrlInput.value = '';
              imageStatus.textContent = 'Optional. Max 5MB.';
              imageStatus.className = 'text-sm text-gray-500 mt-1';
              messageEl.textContent = 'Recipe submitted successfully!';
              messageEl.className = 'mt-4 text-center text-sm text-green-600';
            } else {
              const err = await response.json();
              messageEl.textContent = 'Error: ' + (err.error || 'Something went wrong.');
              messageEl.className = 'mt-4 text-center text-sm text-red-600';
            }
          } catch (error) {
            messageEl.textContent = 'Error: Could not submit recipe. Please try again.';
            messageEl.className = 'mt-4 text-center text-sm text-red-600';
          } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Recipe';
          }
        });
      })();
    </script>
  </div>
{% else %}
  <div class="text-center py-10">
    <p class="text-lg text-gray-600">Please <a href="/account/login" class="text-blue-600 underline">log in</a> to submit a recipe.</p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Recipe Form",
  "settings": []
}
{% endschema %}
