{% assign recipe_blog = blogs[section.settings.blog] %}
{% assign section_heading = section.settings.heading %}
{% if section_heading == blank and recipe_blog != blank %}
  {% assign section_heading = recipe_blog.title %}
{% endif %}

{% if recipe_blog != blank and recipe_blog.articles.size > 0 %}
  <div class="max-w-6xl mx-auto px-4 py-10">
    {% if section_heading != blank %}
      <h2 class="text-3xl font-bold mb-2 text-center uppercase">{{ section_heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="text-center text-gray-600 mb-8">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for article in recipe_blog.articles limit: section.settings.posts_per_page %}
        {% assign handle = article.metafields.custom.product_handle %}
        {% assign linked_product = all_products[handle] %}
        {% assign cook_time = article.metafields.custom.cook_time %}

        <div class="bg-white rounded-xl shadow p-4 border border-gray-100">
          <a href="{{ article.url }}" class="block group">
            {% if article.image != blank %}
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.title }}"
                class="w-full h-48 object-cover rounded-lg mb-4 group-hover:opacity-90 transition"
                loading="lazy"
              >
            {% elsif linked_product.featured_image %}
              <img
                src="{{ linked_product.featured_image | image_url: width: 600 }}"
                alt="{{ linked_product.title }}"
                class="w-full h-48 object-cover rounded-lg mb-4 group-hover:opacity-90 transition"
                loading="lazy"
              >
            {% endif %}

            <h3 class="text-xl font-semibold mb-2 group-hover:underline">{{ article.title }}</h3>
            <p class="text-sm text-gray-600 mb-3">{{ article.excerpt | strip_html | truncatewords: 20 }}</p>

            <div class="flex flex-wrap gap-2 mb-3">
              {% if cook_time != blank %}
                <span class="text-xs bg-gray-100 px-2 py-1 rounded">{{ cook_time }}</span>
              {% endif %}
              {% for tag in article.tags limit: 2 %}
                <span class="text-xs border border-gray-200 px-2 py-1 rounded uppercase">{{ tag }}</span>
              {% endfor %}
            </div>
          </a>

          {% if linked_product %}
            <p class="text-sm mb-2">
              Made using:
              <a href="{{ linked_product.url }}" class="text-[#ffb045] hover:underline font-medium">{{ linked_product.title }}</a>
            </p>
          {% endif %}

          <a href="{{ article.url }}" class="text-[#ffb045] font-semibold hover:underline">{{ section.settings.read_more_text }}</a>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.view_all_link != blank and section.settings.view_all_text != blank %}
      <div class="text-center mt-8">
        <div class="inline-block h-12 bg-[#ffb045] rounded-lg transition-transform duration-300 hover:translate-y-[-0.25rem]">
          <a href="{{ section.settings.view_all_link }}" class="relative uppercase text-lg bg-white text-black border border-black rounded-lg font-bold py-2 px-8 inline-block">
            {{ section.settings.view_all_text }}
          </a>
        </div>
      </div>
    {% endif %}
  </div>
{% elsif section.settings.show_empty_state %}
  <div class="text-center py-10">
    <p class="text-xl text-gray-600">{{ section.settings.empty_state_text }}</p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Recipe List",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Recipes blog only",
      "info": "Do not select the Events blog. Use the separate Events blog for news and markets."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cook with GG's"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Caribbean-inspired recipes using our sauces & marinades"
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more label",
      "default": "Read full recipe"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "See all recipes"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "checkbox",
      "id": "show_empty_state",
      "label": "Show message when no recipes",
      "default": true
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty state message",
      "default": "No recipes yet. Be the first to submit!"
    }
  ],
  "presets": [
    {
      "name": "Recipe List",
      "settings": {
        "blog": "recipes",
        "heading": "Cook with GG's",
        "posts_per_page": 3
      }
    }
  ]
}
{% endschema %}
